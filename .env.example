# Parasol environment configuration
#
# Copy to .env.local and populate. Do not commit .env.local — it is in .gitignore.
# This file is the canonical reference for what env vars exist and what they do.

# ─── Supabase (eu-west-2 London)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ─── Anthropic (Claude Opus 4.7 + Sonnet 4.7 + Haiku 4.5)
# Use Zero-Data-Retention configured account
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-7
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_DEFAULT_MAX_TOKENS=8192
# Sprint 1 default: heavy stages run on Sonnet to set baseline eval scores.
# Sprint 2 A/B tests Opus on compare-playbook and generate-redline (DEF-041).
# Per-stage routing is configured in packages/ai/src/orchestrator.ts via
# stage role tags ('haiku' | 'sonnet' | 'opus'), not env vars directly.

# ─── Voyage AI (embeddings + rerank)
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# ─── Resend (email outbound + inbound, eu-west-1 Ireland)
RESEND_API_KEY=
RESEND_INBOUND_WEBHOOK_SECRET=
# Inbound address pattern (Sprint 1 dev: ask.parasol.co.ke fixed; Sprint 3: per-workspace subdomain via DEF-002)
PARASOL_INBOUND_DOMAIN=parasol.co.ke
PARASOL_INBOUND_SUBDOMAIN=ask
PARASOL_INBOUND_PATTERN=ask@{workspace}.parasol.co.ke
# Sprint 1 fallback for outbound while workspace resolution lands:
PARASOL_OUTBOUND_FROM=Parasol <hello@parasol.co.ke>

# ─── Stripe (Sprint 3+; sandbox keys for dev, live for production)
# Path A architecture: Stripe-only USD billing in v1. M-PESA evaluated Sprint 7 per DEF-042.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
# Locked KES/USD reference rate for KSh price display (revisited quarterly)
PARASOL_KES_USD_RATE=130

# ─── Sentry (error tracking with PII scrubbing per DEF-008)
# NEXT_PUBLIC_SENTRY_DSN is the browser-visible DSN (Sentry DSNs are not secrets)
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN is used by the server-side config; same value as NEXT_PUBLIC_SENTRY_DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─── Audit log integrity
AUDIT_LOG_HASH_SECRET=

# ─── App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
